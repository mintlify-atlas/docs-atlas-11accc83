  "keyFeatures": [
    "Async/await native gRPC client and server",
    "Bi-directional streaming (unary, client-streaming, server-streaming, bidirectional)",
    "TLS support via rustls (ring and aws-lc-rs backends)",
    "Code generation from .proto files via tonic-build and prost",
    "Load balancing with configurable strategies",
    "Interceptors for middleware-style request/response processing",
    "gRPC metadata (custom headers) support",
    "gRPC-Web support via tonic-web",
    "Standard gRPC health checking via tonic-health",
    "gRPC server reflection via tonic-reflection",
    "Message compression (gzip, deflate, zstd)",
    "Built on Tokio, Hyper, and Tower ecosystem"
  ],
